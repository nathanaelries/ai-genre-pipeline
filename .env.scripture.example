# =============================================================================
# ai-genre-pipeline — EXAMPLE CONFIG: "Scripture Meditations / Tanakh + NT"
# =============================================================================
# Calm, long-form scripture-meditation ambient. The songs are SCRIPTURE itself,
# worked from the ORIGINAL languages and translated fresh with a grammatical-
# historical ("originalist") method — which also keeps you clear of translation
# copyright (ancient source texts are public domain; your translation is your
# own). Copy to `.env` and add the two API keys noted below.
#
# Tip: run `... run --dry-run` first — the translation IS the product, so vet the
# rendered passages (pennies) before spending on images.
# -----------------------------------------------------------------------------

# ----------------------------- CREATIVE / GENRE ------------------------------
GENRE="Sacred Cinematic Ambient"
SUB_STYLE="Meditative liturgical ambient with Hebraic modal melodies shaped by Hebrew cantillation (te'amim) and antiphonal, responsorial worship forms — low choir pads, lyre (kinnor), ney flute, hammered dulcimer, distant frame drum, occasional shofar swells; slow, spacious, worshipful."

THEME="Render SCRIPTURE FROM ITS ORIGINAL LANGUAGES, then translate it fresh. Source texts: Biblical Hebrew and the Aramaic portions of the Tanakh (Daniel, Ezra), and Koine Greek for the New Testament — remembering that Jesus and the first disciples taught in Aramaic, so many Gospel sayings carry an Aramaic substrate beneath the Greek. Base it on public-domain / freely-licensed editions (Westminster Leningrad Codex for the Hebrew; SBLGNT or Textus Receptus / Westcott-Hort for the Greek) and ALWAYS produce an ORIGINAL English translation; never reproduce an existing modern translation. Use a grammatical-historical (originalist) method: recover the meaning the author intended for the original audience in its own setting — ancient Near Eastern covenant forms, pastoral and agrarian imagery, Second-Temple Judaism, the Greco-Roman world. Preserve Hebraic parallelism, idiom and wordplay; honor each text's genre and its history of ORAL transmission — much of it was sung, chanted or recited in worship before it was written. DIVINE NAME: never write the Tetragrammaton (no YHWH, no Yahweh, no Hebrew letters); render it with reverent, speakable English titles chosen to fit the passage — 'the LORD', 'God', 'the Almighty', 'the Lord' (Adonai) or 'the Name' (HaShem) — phrased with natural grammar, using second-person 'You' / 'Your' (reverently capitalized) wherever God is addressed directly rather than stiff third-person articles. NAMES: use familiar English names by default (Jesus, the Messiah, the Holy Spirit, the Apostles); reach for a Hebrew form (Yeshua, Mashiach, Ruach HaKodesh) only RARELY, for deliberate emphasis — never as the default. Read the Tanakh and New Testament as one continuous covenant story; no anachronism, no later doctrinal overlay — authorial intent in original context. One passage or theme per track, cited by reference."

MOOD="Reverent, awe-filled, holy, contemplative, solemn yet hopeful."

# The consistency anchor — a single human witness who carries the text across
# both testaments (a Second-Temple-era Judean works in Tanakh AND Gospel scenes).
CHARACTER_DESCRIPTION="A weathered Judean scribe-psalmist in his early sixties: deeply lined olive-bronze skin, deep-set dark brown eyes, a long silver-grey beard reaching mid-chest, thick grey eyebrows, a prominent aquiline nose, shoulder-length grey hair partly covered by a simple undyed linen head-covering. He wears a coarse undyed wool tunic, a faded indigo-and-bone striped wool mantle draped over the left shoulder, a knotted rope belt, and worn leather sandals; calloused hands often cradling a rolled parchment scroll. Calm, reverent bearing."

# Global art direction — historically grounded + reverent (aniconic).
STYLE_GUIDE="Reverent biblical-historical realism, ancient Near East and Second-Temple-era Judea; each scene reflects the specific era and place of its passage (patriarchal nomads, the Exodus wilderness, Davidic Jerusalem, the Babylonian exile, Second-Temple Galilee and Judea). Archaeologically grounded costumes, architecture and landscapes; oil lamps, papyrus and parchment scrolls. Cinematic golden-hour and candlelit light, dust in shafts of sun, weathered stone and linen textures, warm earthen-ochre palette with deep shadow. The divine is NEVER given a face — God's presence appears only as radiant light, fire, cloud, or glory; other sacred figures are shown reverently and indirectly (silhouette, from behind, hands, implied). No anachronisms, no medieval-European or modern dress, no halos, no kitsch, no cartoon styling, no on-screen text, no logos, no watermarks."

# Calm and lingering. Start with one track; scale up once you like the output.
NUM_TRACKS=1
SCENES_PER_TRACK=12
SECONDS_PER_SCENE=10

RESOLUTION="1920x1080"
FPS=24
ASPECT="horizontal"

# ------------------------------- BACKENDS ------------------------------------
LLM_PROVIDER="claude"            # richest, most careful text + reliable structured JSON
MUSIC_BACKEND="prompt_only"      # writes lyrics + a Suno brief; render in Suno (clean rights)
IMAGE_BACKEND="openai"           # cloud (the NUC has no NVIDIA GPU)
# Free still-motion path: VIDEO_BACKEND must be a valid engine, but with the
# Kling keys left blank below every scene falls back to an animated Ken-Burns
# clip of the still — perfect (and free) for calm meditation. `doctor` will
# flag video as "not configured" — that is expected here. Add Kling/Runway keys
# later if you want true motion (the expensive stage).
VIDEO_BACKEND="kling"

LYRICS_OVERLAY=false             # off: burned text can't align to the sung vocals
LIPSYNC=false                    # no speaking character

# ------------------------------- API KEYS ------------------------------------
# This config needs exactly two: ANTHROPIC_API_KEY (LLM) and OPENAI_API_KEY (images).
ANTHROPIC_API_KEY=""             # REQUIRED (LLM_PROVIDER=claude)
OPENAI_API_KEY=""                # REQUIRED (IMAGE_BACKEND=openai)
XAI_API_KEY=""

# Music — only if you switch MUSIC_BACKEND to suno_thirdparty.
SUNO_API_BASE="https://api.sunoapi.org"
SUNO_API_KEY=""

# Video — leave blank to use the free Ken-Burns fallback (see VIDEO_BACKEND note).
KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""
KLING_API_BASE="https://api.klingai.com"
RUNWAY_API_KEY=""
RUNWAY_API_BASE="https://api.dev.runwayml.com"

# Local ComfyUI (only if IMAGE_BACKEND or VIDEO_BACKEND = comfyui).
COMFYUI_URL="http://localhost:8188"
COMFYUI_CKPT="sd_xl_base_1.0.safetensors"
COMFYUI_IMAGE_WORKFLOW=""
COMFYUI_VIDEO_WORKFLOW=""

# Model id overrides (optional).
OPENAI_IMAGE_MODEL="gpt-image-1"
RUNWAY_MODEL="gen3a_turbo"
KLING_MODEL="kling-v1"

# ------------------------------- RUNTIME -------------------------------------
OUTPUT_DIR="outputs"
RUN_NAME="scripture-meditations"
SEED=7
LOG_LEVEL="INFO"
LOG_PRETTY=true

# ---------------------------- LIVE STREAMING ---------------------------------
# Prove a run first; enable later for a 24/7 channel. See .env.example for the
# full streaming reference.
STREAM_ENABLED=false
STREAM_TARGETS="youtube"
STREAM_MODE="after"
STREAM_LOOP_WHEN_IDLE=true
STREAM_VIDEO_BITRATE="4500k"
STREAM_AUDIO_BITRATE="128k"
STREAM_PRESET="veryfast"

YOUTUBE_INGEST_URL="rtmp://a.rtmp.youtube.com/live2"
YOUTUBE_STREAM_KEY=""
FACEBOOK_INGEST_URL="rtmps://live-api-s.facebook.com:443/rtmp"
FACEBOOK_STREAM_KEY=""
TIKTOK_INGEST_URL=""
TIKTOK_STREAM_KEY=""
RUMBLE_INGEST_URL=""
RUMBLE_STREAM_KEY=""
CUSTOM_INGEST_URL=""
