# =============================================================================
# ai-genre-pipeline — EXAMPLE CONFIG: "Relaxing Deep House / Serene Ocean"
# =============================================================================
# Copy this to `.env` and fill in the API keys for the backends you enable.
# Spinning up a brand-new genre = copy this file and edit the CREATIVE block.
# Everything the pipeline does is driven from here; no code changes required.
# -----------------------------------------------------------------------------

# ----------------------------- CREATIVE / GENRE ------------------------------
GENRE="Deep House"
SUB_STYLE="Melodic, organic deep house with lo-fi warmth"
THEME="A lone surfer and the living ocean at golden hour; calm, vast, meditative"
MOOD="Serene, hypnotic, nostalgic, weightless"

# The single most important field for character consistency. Be SPECIFIC and
# physical (age, build, hair, wardrobe, distinguishing features). This exact
# text is reused verbatim in every image/video prompt.
CHARACTER_DESCRIPTION="A 30-year-old woman with sun-bleached shoulder-length wavy blonde hair, light freckles, calm green eyes, wearing a weathered teal wetsuit with the zipper pulled half-down over a white rash guard, a thin braided leather bracelet on her right wrist. Lean swimmer's build, relaxed posture."

# Global art-direction rules applied to every scene.
STYLE_GUIDE="Cinematic, soft natural light, anamorphic lens flares, shallow depth of field, gentle film grain, 35mm aesthetic, muted teal-and-amber color grade, no text, no logos, no harsh contrast."

# How much to make. NUM_TRACKS songs, each with SCENES_PER_TRACK shots.
NUM_TRACKS=1
SCENES_PER_TRACK=8
SECONDS_PER_SCENE=8

# Output video geometry.
RESOLUTION="1920x1080"
FPS=24
# horizontal | vertical | square — convenience preset that overrides RESOLUTION
ASPECT="horizontal"

# ------------------------------- BACKENDS ------------------------------------
# Which engine powers each stage. Mix and match freely.
LLM_PROVIDER="claude"            # claude | openai | grok
MUSIC_BACKEND="prompt_only"      # suno_thirdparty | local | prompt_only
IMAGE_BACKEND="openai"           # openai | comfyui
VIDEO_BACKEND="kling"            # kling | runway | comfyui

# Add a karaoke-style lyric overlay onto the final video.
LYRICS_OVERLAY=true
# Attempt lip-sync (only meaningful with VIDEO_BACKEND=comfyui).
LIPSYNC=false

# ------------------------------- API KEYS ------------------------------------
# Only the keys for the backends you selected above are required.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
XAI_API_KEY=""                   # Grok (x.ai)

# Music — third-party Suno provider (EvoLink, 302.ai, sunoapi.org, ...)
SUNO_API_BASE="https://api.sunoapi.org"
SUNO_API_KEY=""

# Video — Kling (Kuaishou) / Runway Gen-3
KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""
KLING_API_BASE="https://api.klingai.com"
RUNWAY_API_KEY=""
RUNWAY_API_BASE="https://api.dev.runwayml.com"

# Local ComfyUI (when IMAGE_BACKEND or VIDEO_BACKEND = comfyui)
COMFYUI_URL="http://localhost:8188"
COMFYUI_CKPT="sd_xl_base_1.0.safetensors"
# Optional: exported API-format workflow JSON. For images this enables true
# IP-Adapter/ControlNet character locking; for video it is REQUIRED.
# Supported tokens: %POSITIVE% %NEGATIVE% %SEED% %WIDTH% %HEIGHT% %CKPT%
#                   %REF_IMAGE% %PROMPT% %FRAMES% %FPS%
COMFYUI_IMAGE_WORKFLOW=""
COMFYUI_VIDEO_WORKFLOW=""

# Model id overrides (optional — sensible defaults are used if blank/omitted)
OPENAI_IMAGE_MODEL="gpt-image-1"
RUNWAY_MODEL="gen3a_turbo"
KLING_MODEL="kling-v1"

# ------------------------------- RUNTIME -------------------------------------
# Where runs are written (host path is mounted into the container).
OUTPUT_DIR="outputs"
# Optional: pin a run folder name. If blank, one is derived from genre + theme.
RUN_NAME=""
# Reuse a deterministic seed across image/video for tighter consistency.
SEED=42
LOG_LEVEL="INFO"                 # DEBUG | INFO | WARNING | ERROR
# Pretty rich console logs (true) vs JSON lines for shipping (false).
LOG_PRETTY=true

# ---------------------------- LIVE STREAMING ---------------------------------
# Push generated videos to live platforms over RTMP/RTMPS. As each video is
# produced it is queued into a single seamless stream that loops forever, so
# playback never stops. One encode fans out to every platform below at once.
STREAM_ENABLED=false
# Comma-separated: youtube, tiktok, facebook (covers Instagram), rumble, custom
STREAM_TARGETS="youtube"
# after = generate everything, then stream the library on a loop
# live  = start streaming immediately; new clips join the stream as they finish
STREAM_MODE="after"
# Re-loop the existing library whenever the queue is empty (the never-stop part).
STREAM_LOOP_WHEN_IDLE=true
# Live encoder settings (the single push encode that is fanned out to platforms).
STREAM_VIDEO_BITRATE="4500k"
STREAM_AUDIO_BITRATE="128k"
STREAM_PRESET="veryfast"         # ultrafast..veryslow (speed vs quality)

# --- Per-platform ingest ---
# YouTube Live: create a stream in YouTube Studio and paste its key here.
YOUTUBE_INGEST_URL="rtmp://a.rtmp.youtube.com/live2"
YOUTUBE_STREAM_KEY=""
# Facebook / Instagram Live: Live Producer gives a server URL + stream key.
FACEBOOK_INGEST_URL="rtmps://live-api-s.facebook.com:443/rtmp"
FACEBOOK_STREAM_KEY=""
# TikTok Live (needs LIVE access / TikTok Live Studio). Paste the RTMP server
# URL and key it gives you. If the URL already contains the key, leave key blank.
TIKTOK_INGEST_URL=""
TIKTOK_STREAM_KEY=""
# Rumble: copy the full RTMP URL (and/or key) from your Rumble stream settings.
RUMBLE_INGEST_URL=""
RUMBLE_STREAM_KEY=""
# Any other RTMP/RTMPS destination (e.g. Twitch, a local nginx-rtmp relay).
CUSTOM_INGEST_URL=""
