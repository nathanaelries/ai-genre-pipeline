# Secrets / config
.env
.env.*
!.env.example
!.env.*.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Pipeline output (generated media can be large — never commit)
# Ignore everything under outputs/ except the placeholder that keeps the dir.
outputs/*
!outputs/.gitkeep

# Host drop-folder for imported audio/files — keep the dir, ignore contents.
inbox/*
!inbox/.gitkeep

# Local-only scratch: exported MCP tool schemas (not part of this project).
mcps/

# Machine-specific Docker overrides (volume mounts, ports, etc.) — keep local so
# they never conflict on `git pull`. Compose auto-merges this on top of the base.
docker-compose.override.yml

# Local model / tool caches
comfyui/models/
.cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
