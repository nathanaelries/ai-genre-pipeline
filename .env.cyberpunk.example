# =============================================================================
# ai-genre-pipeline — EXAMPLE CONFIG: "Cyberpunk Synthwave / Neon Megacity"
# =============================================================================
# A completely different genre — note ONLY the CREATIVE block + some backend
# choices changed. Copy to `.env` to use.
# -----------------------------------------------------------------------------

# ----------------------------- CREATIVE / GENRE ------------------------------
GENRE="Synthwave"
SUB_STYLE="Dark cyberpunk synthwave with driving arps and analog bass"
THEME="A rogue netrunner courier weaving through a rain-soaked neon megacity at night"
MOOD="Tense, glamorous, melancholic, electric"

CHARACTER_DESCRIPTION="A 25-year-old androgynous netrunner with an undercut and slicked-back jet-black hair, a faint glowing cyan circuit tattoo along the left jaw, mirrored chrome augmented eyes, wearing a cropped black techwear jacket with magenta piping and a high collar, fingerless gloves. Sharp cheekbones, confident smirk."

STYLE_GUIDE="Neon-noir, blade-runner aesthetic, volumetric haze, heavy rain, reflective wet asphalt, cyan-and-magenta color grade, deep blacks, glowing holographic signage, cinematic 2.39:1, anamorphic flares, no on-screen text, no watermarks."

NUM_TRACKS=1
SCENES_PER_TRACK=10
SECONDS_PER_SCENE=6

RESOLUTION="1920x1080"
FPS=24
ASPECT="horizontal"

# ------------------------------- BACKENDS ------------------------------------
LLM_PROVIDER="openai"            # claude | openai | grok
MUSIC_BACKEND="suno_thirdparty"  # suno_thirdparty | local | prompt_only
IMAGE_BACKEND="comfyui"          # openai | comfyui
VIDEO_BACKEND="runway"           # kling | runway | comfyui

LYRICS_OVERLAY=true
LIPSYNC=false

# ------------------------------- API KEYS ------------------------------------
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
XAI_API_KEY=""

SUNO_API_BASE="https://api.sunoapi.org"
SUNO_API_KEY=""

KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""
KLING_API_BASE="https://api.klingai.com"
RUNWAY_API_KEY=""
RUNWAY_API_BASE="https://api.dev.runwayml.com"

COMFYUI_URL="http://localhost:8188"

# ------------------------------- RUNTIME -------------------------------------
OUTPUT_DIR="outputs"
RUN_NAME=""
SEED=1337
LOG_LEVEL="INFO"
LOG_PRETTY=true

# ---------------------------- LIVE STREAMING ---------------------------------
# See .env.example for the full streaming reference + all platform keys.
STREAM_ENABLED=false
STREAM_TARGETS="youtube,rumble"
STREAM_MODE="live"               # stream as clips are generated
STREAM_LOOP_WHEN_IDLE=true
STREAM_VIDEO_BITRATE="6000k"
STREAM_AUDIO_BITRATE="160k"
STREAM_PRESET="veryfast"

YOUTUBE_INGEST_URL="rtmp://a.rtmp.youtube.com/live2"
YOUTUBE_STREAM_KEY=""
FACEBOOK_INGEST_URL="rtmps://live-api-s.facebook.com:443/rtmp"
FACEBOOK_STREAM_KEY=""
TIKTOK_INGEST_URL=""
TIKTOK_STREAM_KEY=""
RUMBLE_INGEST_URL=""
RUMBLE_STREAM_KEY=""
CUSTOM_INGEST_URL=""
