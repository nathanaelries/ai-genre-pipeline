# =============================================================================
# ai-genre-pipeline — EXAMPLE CONFIG: "Emotional Country Trance / Dust & Sky"
# =============================================================================
# A third genre to show range. Copy to `.env` to use.
# -----------------------------------------------------------------------------

# ----------------------------- CREATIVE / GENRE ------------------------------
GENRE="Country Trance"
SUB_STYLE="Emotional country-trance crossover: slide guitar over euphoric supersaws"
THEME="An old rancher and his horse crossing endless golden plains toward a coming storm"
MOOD="Bittersweet, hopeful, expansive, cathartic"

CHARACTER_DESCRIPTION="A weathered 60-year-old rancher with a thick grey moustache, deep sun-creased skin, kind tired blue eyes, wearing a dusty tan cowboy hat, a faded denim jacket over a checkered flannel shirt, and a silver belt buckle. Broad shoulders, slight stoop, calloused hands."

STYLE_GUIDE="Epic cinematic Americana, golden-hour backlight, dust motes in the air, wide vistas, warm amber-and-gold grade with deep shadows, 70mm film look, gentle grain, lens flares, no text, no logos."

NUM_TRACKS=1
SCENES_PER_TRACK=8
SECONDS_PER_SCENE=8

RESOLUTION="1920x1080"
FPS=24
ASPECT="horizontal"

# ------------------------------- BACKENDS ------------------------------------
LLM_PROVIDER="grok"              # claude | openai | grok
MUSIC_BACKEND="prompt_only"      # suno_thirdparty | local | prompt_only
IMAGE_BACKEND="openai"           # openai | comfyui
VIDEO_BACKEND="kling"            # kling | runway | comfyui

LYRICS_OVERLAY=true
LIPSYNC=false

# ------------------------------- API KEYS ------------------------------------
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
XAI_API_KEY=""

SUNO_API_BASE="https://api.sunoapi.org"
SUNO_API_KEY=""

KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""
KLING_API_BASE="https://api.klingai.com"
RUNWAY_API_KEY=""
RUNWAY_API_BASE="https://api.dev.runwayml.com"

COMFYUI_URL="http://localhost:8188"

# ------------------------------- RUNTIME -------------------------------------
OUTPUT_DIR="outputs"
RUN_NAME=""
SEED=7
LOG_LEVEL="INFO"
LOG_PRETTY=true

# ---------------------------- LIVE STREAMING ---------------------------------
# See .env.example for the full streaming reference + all platform keys.
STREAM_ENABLED=false
STREAM_TARGETS="youtube"
STREAM_MODE="after"              # build the library first, then loop it 24/7
STREAM_LOOP_WHEN_IDLE=true
STREAM_VIDEO_BITRATE="4500k"
STREAM_AUDIO_BITRATE="128k"
STREAM_PRESET="veryfast"

YOUTUBE_INGEST_URL="rtmp://a.rtmp.youtube.com/live2"
YOUTUBE_STREAM_KEY=""
FACEBOOK_INGEST_URL="rtmps://live-api-s.facebook.com:443/rtmp"
FACEBOOK_STREAM_KEY=""
TIKTOK_INGEST_URL=""
TIKTOK_STREAM_KEY=""
RUMBLE_INGEST_URL=""
RUMBLE_STREAM_KEY=""
CUSTOM_INGEST_URL=""
